# Copy to .env in the repo root for docker compose:
#   cp .env.docker.example .env

# Neon PostgreSQL (Console → Connect)
# Pooled connection — used by the app at runtime
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Direct connection — used by Prisma migrate deploy on container start
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Host ports exposed on your machine
CLIENT_PORT=3000
SERVER_PORT=5000

# Browser-facing URLs (must match how you open the app from the host)
CLIENT_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:5000
